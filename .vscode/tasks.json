{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Log tracking result",
            "type": "shell",
            "command": "conda run -n btrack2 python3 scripts/log_tracking_result.py",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "group": "none",
            "problemMatcher": []
        },
        {
